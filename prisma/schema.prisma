generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Application users. Currently a single admin user, designed for easy expansion.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

/// One record per calendar day, capturing traffic, visitors, buyers and context.
model DailyRecord {
  id   String   @id @default(cuid())
  date DateTime @unique @db.Date

  // Traffic
  foreignPassers Int @default(0)
  localPassers   Int @default(0)

  // Visitors
  foreignVisitors Int @default(0)
  localVisitors   Int @default(0)

  // Buyers
  foreignBuyers Int @default(0)
  localBuyers   Int @default(0)

  // Context
  weather      String?
  dayType      String?
  specialNotes String?

  // Text areas
  missingProducts String?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]

  @@map("daily_records")
  @@index([date])
}

enum SaleType {
  foreign
  local
}

/// A single sale transaction, always linked to a DailyRecord.
model Sale {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  type      SaleType
  amountKes Decimal  @db.Decimal(12, 2)
  items     String?

  dailyRecordId String
  dailyRecord   DailyRecord @relation(fields: [dailyRecordId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("sales")
  @@index([dailyRecordId])
  @@index([date])
  @@index([type])
}

enum ImprovementType {
  Signage
  Product
  Promotion
  Layout
  Pricing
  Staff
  Other
}

/// Operational improvements made to the store, used for before/after impact analysis.
model Improvement {
  id                 String          @id @default(cuid())
  title              String
  type               ImprovementType
  description        String?
  implementationDate DateTime        @db.Date
  createdAt          DateTime        @default(now())

  @@map("improvements")
  @@index([implementationDate])
}
