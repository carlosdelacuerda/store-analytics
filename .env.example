# PostgreSQL connection string
# Example (Vercel Postgres / Neon / Supabase): postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/store_analytics?schema=public"

# Secret used to sign JWT session tokens. Generate with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-secret-value"
